### Project API Tests
### Tests for ProjectController endpoints
### Uses {{baseUrl}} from http-client.env.json

### List all projects
GET {{baseUrl}}/api/projects
Content-Type: application/json

> {%
  client.assert(response.status === 200, "List projects should return 200");
  client.log("Projects count: " + response.body.length);
%}

### Get current project
GET {{baseUrl}}/api/projects/current
Content-Type: application/json

> {%
  client.assert(response.status === 200, "Current project should return 200");
  client.log("Current project: " + response.body.id);
%}

### Update current project
PATCH {{baseUrl}}/api/projects/current
Content-Type: application/json

{
  "commands": {
    "build": "mvn clean install",
    "test": "mvn test"
  }
}

> {%
  client.assert(response.status === 200, "Update project should return 200");
  client.log("Project updated");
%}
