### Configuration API Tests
### Tests for ConfigurationController endpoints
### Uses {{baseUrl}} from http-client.env.json

### Get project configuration
GET {{baseUrl}}/api/config/project
Content-Type: application/json

> {%
  client.assert(response.status === 200, "Get config should return 200");
  client.log("Project config retrieved");
%}

### Get global configuration
GET {{baseUrl}}/api/config/global
Content-Type: application/json

> {%
  client.assert(response.status === 200, "Get global config should return 200");
  client.log("Global config retrieved");
%}

### Get available providers configuration
GET {{baseUrl}}/api/config/providers
Content-Type: application/json

> {%
  client.assert(response.status === 200, "Get providers config should return 200");
  client.log("Providers config retrieved");
%}

### Update project configuration
PATCH {{baseUrl}}/api/config/project
Content-Type: application/json

{
  "agent": {
    "name": "opencode"
  },
  "model": "glm-4.7"
}

> {%
  client.assert(response.status === 200, "Update config should return 200");
  client.log("Config updated");
%}
