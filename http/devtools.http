### DevTools API Tests
### Tests for DevToolsController endpoints
### Uses {{baseUrl}} from http-client.env.json

### Get LSP status
GET {{baseUrl}}/api/devtools/lsp
Content-Type: application/json

> {%
  client.assert(response.status === 200, "LSP status should return 200");
  client.log("LSP status retrieved");
%}

### Get formatter status
GET {{baseUrl}}/api/devtools/formatter
Content-Type: application/json

> {%
  client.assert(response.status === 200, "Formatter status should return 200");
  client.log("Formatter status retrieved");
%}

### Send log message
POST {{baseUrl}}/api/devtools/log
Content-Type: application/json

{
  "service": "test-service",
  "level": "info",
  "message": "Test log message from HTTP client"
}

> {%
  client.assert(response.status === 200, "Log should return 200");
  client.log("Log sent");
%}
