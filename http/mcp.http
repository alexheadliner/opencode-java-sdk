### MCP (Model Context Protocol) API Tests
### Tests for McpController endpoints
### Self-contained: discovers MCP server name from list, then tests endpoints.
### Run requests top-to-bottom.

### 1. Get all MCP servers (captures first server name)
GET {{baseUrl}}/api/mcp
Content-Type: application/json

> {%
  client.assert(response.status === 200, "MCP list should return 200");
  const keys = Object.keys(response.body);
  if (keys.length > 0) {
    client.global.set("mcpName", keys[0]);
    client.log("Found MCP server: " + keys[0]);
  } else {
    client.log("No MCP servers found");
  }
%}

### 2. Get MCP server status
GET {{baseUrl}}/api/mcp/{{mcpName}}/status
Content-Type: application/json

> {%
  client.log("MCP status response: " + response.status);
%}

### 3. Add MCP server
POST {{baseUrl}}/api/mcp
Content-Type: application/json

{
  "name": "test-mcp-server",
  "command": "echo",
  "args": ["hello"]
}

> {%
  client.log("Add MCP response: " + response.status);
%}

### 4. Start MCP authentication
POST {{baseUrl}}/api/mcp/{{mcpName}}/auth/start
Content-Type: application/json

> {%
  client.log("MCP auth start response: " + response.status);
%}

### 5. Handle MCP OAuth callback
POST {{baseUrl}}/api/mcp/{{mcpName}}/auth/callback
Content-Type: application/json

{
  "code": "oauth_authorization_code",
  "state": "oauth_state_parameter"
}

> {%
  client.log("MCP auth callback response: " + response.status);
%}

### 6. Remove MCP authentication
DELETE {{baseUrl}}/api/mcp/{{mcpName}}/auth
Content-Type: application/json

> {%
  client.log("MCP auth remove response: " + response.status);
  client.global.set("mcpName", "");
%}
