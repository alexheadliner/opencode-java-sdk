### PTY (Pseudo-Terminal) API Tests
### Tests for PtyController endpoints
### Self-contained: lists PTY sessions first (create may fail on some servers).
### Run requests top-to-bottom.

### 1. Get all PTY sessions
GET {{baseUrl}}/api/pty
Content-Type: application/json

> {%
  client.assert(response.status === 200, "List PTY should return 200");
  client.log("PTY sessions count: " + response.body.length);
%}

### 2. Create new PTY session (captures ptyId)
### Note: May return 500 if the OpenCode server does not support PTY creation
POST {{baseUrl}}/api/pty
Content-Type: application/json

{
  "command": "/bin/bash",
  "rows": 24,
  "cols": 80
}

> {%
  if (response.status === 200) {
    client.global.set("ptyId", response.body.id);
    client.log("Created PTY: " + response.body.id);
  } else {
    client.log("PTY create returned " + response.status + " — server may not support PTY");
  }
%}

### 3. Get specific PTY session (skip if create failed)
GET {{baseUrl}}/api/pty/{{ptyId}}
Content-Type: application/json

> {%
  client.assert(response.status === 200 || response.status === 404, "Get PTY should return 200 or 404");
  client.log("Got PTY response: " + response.status);
%}

### 4. Update PTY session size
PATCH {{baseUrl}}/api/pty/{{ptyId}}
Content-Type: application/json

{
  "size": {
    "rows": 40,
    "cols": 100
  }
}

> {%
  client.assert(response.status === 200 || response.status === 404, "Update PTY should return 200 or 404");
  client.log("PTY size update response: " + response.status);
%}

### 5. Write to PTY session
PATCH {{baseUrl}}/api/pty/{{ptyId}}
Content-Type: application/json

{
  "input": "ls -la\n"
}

> {%
  client.assert(response.status === 200 || response.status === 404, "Write PTY should return 200 or 404");
  client.log("Write to PTY response: " + response.status);
%}

### 6. Delete PTY session (cleanup)
DELETE {{baseUrl}}/api/pty/{{ptyId}}
Content-Type: application/json

> {%
  client.assert(response.status === 200 || response.status === 404, "Delete PTY should return 200 or 404");
  client.log("PTY delete response: " + response.status);
  client.global.set("ptyId", "");
%}
