### Experimental API Tests
### Tests for ExperimentalController endpoints
### Uses {{baseUrl}} from http-client.env.json

### Create workspace
POST {{baseUrl}}/api/experimental/workspace
Content-Type: application/json

{
  "name": "my-experimental-workspace",
  "path": "/projects/my-project"
}

> {%
  client.assert(response.status === 200, "Create workspace should return 200");
  client.log("Workspace created");
%}

### Get worktree list
GET {{baseUrl}}/api/experimental/worktree
Content-Type: application/json

> {%
  client.assert(response.status === 200, "List worktree should return 200");
  client.log("Worktrees count: " + response.body.length);
%}

### Create worktree
POST {{baseUrl}}/api/experimental/worktree
Content-Type: application/json

{
  "branch": "feature/new-feature",
  "path": "/projects/my-project-worktree"
}

> {%
  client.assert(response.status === 200, "Create worktree should return 200");
  client.log("Worktree created");
%}

### Remove worktree
DELETE {{baseUrl}}/api/experimental/worktree
Content-Type: application/json

{
  "path": "/projects/my-project-worktree"
}

> {%
  client.assert(response.status === 200, "Remove worktree should return 200");
  client.log("Worktree removed");
%}
