### Session CRUD API Tests
### Tests for SessionCrudController endpoints
### Self-contained: creates a session, then tests CRUD, then cleans up.
### Run requests top-to-bottom.

### 1. List all sessions
GET {{baseUrl}}/api/sessions
Content-Type: application/json

> {%
  client.assert(response.status === 200, "List sessions should return 200");
  client.log("Sessions: " + response.body.length);
%}

### 2. Create new session (captures sessionId)
POST {{baseUrl}}/api/sessions
Content-Type: application/json

{
  "agent": "opencode"
}

> {%
  client.global.set("sessionId", response.body.id);
  client.assert(response.status === 200, "Create session should return 200");
  client.assert(response.body.id !== undefined, "Response should contain session id");
  client.log("Created session: " + response.body.id);
%}

### 3. Get session by ID
GET {{baseUrl}}/api/sessions/{{sessionId}}
Content-Type: application/json

> {%
  client.assert(response.status === 200, "Get session should return 200");
  client.log("Got session: " + response.body.id);
%}

### 4. Update session
PATCH {{baseUrl}}/api/sessions/{{sessionId}}
Content-Type: application/json

{
  "title": "Updated session title"
}

> {%
  client.assert(response.status === 204, "Update session should return 204");
  client.log("Session updated");
%}

### 5. Delete session (cleanup)
DELETE {{baseUrl}}/api/sessions/{{sessionId}}
Content-Type: application/json

> {%
  client.assert(response.status === 204, "Delete session should return 204");
  client.log("Session deleted: " + client.global.get("sessionId"));
  client.global.set("sessionId", "");
%}
